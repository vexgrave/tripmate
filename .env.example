# Скопируйте этот файл в .env и заполните своими значениями.
# Файл .env никогда не должен попадать в git (см. .gitignore).

SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- VK OAuth ---
# Получить client_id/secret: https://id.vk.com/business/go -> создать VK ID приложение.
# Redirect URI для VK-приложения (callback), который нужно указать в настройках VK-приложения:
#   http://127.0.0.1:8000/accounts/3rdparty/vk/login/callback/
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# --- Telegram Login Widget ---
# 1. Создайте бота через @BotFather, получите токен.
# 2. Командой /setdomain в @BotFather привяжите бота к домену, на котором крутится сайт
#    (для локальной разработки Telegram Login Widget требует https и публичный домен,
#    поэтому для чистого localhost потребуется туннель, например ngrok).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# --- MAX ---
# Официального OAuth/Login API для MAX на момент разработки нет.
# Кнопка "Войти через MAX" ведёт на страницу-заглушку "Функция в разработке".
MAX_AUTH_ENABLED=False
